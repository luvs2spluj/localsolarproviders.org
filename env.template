# Local Solar Providers - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# NREL API Key (Required for real solar calculations)
# =============================================================================
# Get your free key at: https://developer.nrel.gov/
NREL_API_KEY=your_nrel_api_key_here

# =============================================================================
# Supabase Configuration (Required for database operations)
# =============================================================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# Clerk Authentication (Optional - for saving installers lists)
# =============================================================================
# Get these from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# =============================================================================
# Database Configuration (Optional - uses Supabase by default)
# =============================================================================
# Only needed if you want to use a separate PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/solarproviders
DIRECT_URL=postgresql://username:password@localhost:5432/solarproviders

# =============================================================================
# OpenAI API Key (Required for embeddings and AI features)
# =============================================================================
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Solar API Keys (Optional)
# =============================================================================
# Additional solar data APIs
SOLAR_API_KEY=your_solar_api_key_here
ENERGY_SAGE_API_KEY=your_energy_sage_api_key_here

# =============================================================================
# External Service APIs (Optional)
# =============================================================================
# Yelp Fusion API for business data
YELP_API_KEY=your_yelp_api_key_here

# Google Custom Search API (if needed for web scraping)
GOOGLE_CSE_ID=your_google_cse_id_here
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# Application Configuration
# =============================================================================
# Environment
NODE_ENV=development

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Security
# =============================================================================
# JWT Secret for API authentication
JWT_SECRET=your_jwt_secret_here

# API Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# =============================================================================
# Monitoring and Analytics (Optional)
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
NEXT_PUBLIC_GA_ID=your_google_analytics_id_here

# =============================================================================
# Email Configuration (Optional)
# =============================================================================
# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# =============================================================================
# File Storage (Optional)
# =============================================================================
# AWS S3 for file uploads
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name_here

# =============================================================================
# Development Tools (Optional)
# =============================================================================
# Debug mode
DEBUG=false

# Log level
LOG_LEVEL=info

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit .env.local to version control
# 2. Copy this template to .env.local and fill in your values
# 3. For production, set these variables in your deployment platform
# 4. Some services offer free tiers that are sufficient for development
# 5. Always use environment-specific values for production vs development
